{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://volunteer-flow-production.up.railway.app/api/$1"
    },
    {
      "source": "/sanctum/(.*)",
      "destination": "https://volunteer-flow-production.up.railway.app/sanctum/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
